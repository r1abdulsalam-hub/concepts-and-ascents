---
import BaseLayout from '../layouts/BaseLayout.astro';

const today = new Date().toISOString().slice(0, 10);
---

<BaseLayout
  title="Admin"
  description="Internal admin for adding essays."
>
  <article class="admin">
    <h1 class="essay-title">Admin</h1>
    <hr class="essay-rule" />

    <section id="signed-out" class="admin-pane" hidden>
      <p class="admin-intro">
        Paste a GitHub fine-grained personal access token with
        <em>Contents: Read and write</em> permission for this repository to sign in.
        The token is stored only in your browser's local storage.
      </p>
      <form id="signin-form" class="admin-form" novalidate>
        <div class="field">
          <label class="label" for="pat">Personal access token</label>
          <input
            id="pat"
            name="pat"
            type="password"
            autocomplete="off"
            spellcheck="false"
            required
            placeholder="github_pat_..."
          />
        </div>
        <p id="signin-error" class="message error" hidden></p>
        <button type="submit" class="button" id="signin-btn">Sign in</button>
      </form>
    </section>

    <section id="signed-in" class="admin-pane" hidden>
      <div class="admin-bar">
        <span class="label">Signed in</span>
        <button id="signout-btn" type="button" class="link-button">Sign out</button>
      </div>

      <form id="essay-form" class="admin-form" novalidate>
        <div class="field">
          <label class="label" for="title">Title</label>
          <input id="title" name="title" type="text" required spellcheck="true" />
        </div>

        <div class="field">
          <label class="label" for="subtitle">Subtitle <span class="optional">optional</span></label>
          <input id="subtitle" name="subtitle" type="text" spellcheck="true" />
          <small class="hint">Set in italic beneath the title.</small>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="label" for="date">Date</label>
            <input id="date" name="date" type="date" required value={today} />
          </div>
          <div class="field field-checkbox">
            <input id="draft" name="draft" type="checkbox" checked />
            <label class="label" for="draft">Draft</label>
            <small class="hint">Excluded from archive, RSS, and sitemap until unchecked.</small>
          </div>
        </div>

        <div class="field">
          <label class="label" for="description">Description <span class="optional">optional</span></label>
          <input id="description" name="description" type="text" spellcheck="true" />
          <small class="hint">For meta tags and the RSS feed. About one sentence.</small>
        </div>

        <div class="field field-body">
          <div class="body-header">
            <label class="label" for="body">Body</label>
            <span class="hint hint-inline">
              Plain Markdown. <code>---</code> for an asterism (⁂).
              <code>[^1]</code> with <code>[^1]: text</code> at the bottom for a footnote.
              <code>&lt;Sidenote&gt;…&lt;/Sidenote&gt;</code> for a margin note.
            </span>
          </div>
          <div class="body-split">
            <textarea
              id="body"
              name="body"
              required
              spellcheck="true"
              placeholder="Write the essay here…"
            ></textarea>
            <div class="preview-pane">
              <div class="essay-body" id="preview"></div>
            </div>
          </div>
        </div>

        <p id="publish-error" class="message error" hidden></p>
        <p id="publish-success" class="message success" hidden></p>

        <div class="actions">
          <button type="submit" class="button" id="publish-btn">Publish</button>
          <button type="button" class="link-button" id="reset-btn">Clear form</button>
        </div>
      </form>
    </section>
  </article>
</BaseLayout>

<script type="module" is:inline>
  import { marked } from 'https://esm.sh/marked@13';
  import markedFootnote from 'https://esm.sh/marked-footnote@1';
  import { markedSmartypants } from 'https://esm.sh/marked-smartypants@1';

  marked.use(markedFootnote());
  marked.use(markedSmartypants());

  const REPO = 'r1abdulsalam-hub/concepts-and-ascents';
  const ESSAYS_PATH = 'src/content/essays';
  const STORAGE_KEY = 'cna_pat';
  const API = 'https://api.github.com';

  const $ = (id) => document.getElementById(id);

  const signedOut = $('signed-out');
  const signedIn = $('signed-in');
  const signinForm = $('signin-form');
  const signinError = $('signin-error');
  const signinBtn = $('signin-btn');
  const patInput = $('pat');
  const signoutBtn = $('signout-btn');
  const essayForm = $('essay-form');
  const publishBtn = $('publish-btn');
  const publishError = $('publish-error');
  const publishSuccess = $('publish-success');
  const bodyInput = $('body');
  const preview = $('preview');
  const resetBtn = $('reset-btn');

  function showSignedOut() {
    signedOut.hidden = false;
    signedIn.hidden = true;
    patInput.value = '';
    setTimeout(() => patInput.focus(), 0);
  }

  function showSignedIn() {
    signedOut.hidden = true;
    signedIn.hidden = false;
    setTimeout(() => $('title').focus(), 0);
  }

  function setMessage(el, text, kind) {
    el.textContent = text;
    el.hidden = !text;
    if (kind === 'html') el.innerHTML = text;
  }

  async function ghFetch(path, init = {}) {
    const token = localStorage.getItem(STORAGE_KEY);
    const res = await fetch(`${API}${path}`, {
      ...init,
      headers: {
        Accept: 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28',
        Authorization: `Bearer ${token}`,
        ...(init.headers || {}),
        ...(init.body ? { 'Content-Type': 'application/json' } : {}),
      },
    });
    return res;
  }

  function slugify(s) {
    return s
      .toLowerCase()
      .normalize('NFKD')
      .replace(/[̀-ͯ]/g, '')
      .replace(/[‘’']/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .replace(/-{2,}/g, '-');
  }

  function yamlString(s) {
    if (!/[:#\-?@!&*|>'"%`,\[\]\{\}]|^\s|\s$/.test(s)) return s;
    return `"${s.replace(/\\/g, '\\\\').replace(/"/g, '\\"')}"`;
  }

  function buildMdx({ title, subtitle, date, description, draft, body }) {
    const lines = ['---'];
    lines.push(`title: ${yamlString(title)}`);
    if (subtitle) lines.push(`subtitle: ${yamlString(subtitle)}`);
    lines.push(`date: ${date}`);
    if (description) lines.push(`description: ${yamlString(description)}`);
    if (draft) lines.push('draft: true');
    lines.push('---', '', body.trim(), '');
    return lines.join('\n');
  }

  function utf8ToBase64(str) {
    return btoa(String.fromCharCode(...new TextEncoder().encode(str)));
  }

  // --- Sign in ---------------------------------------------------------

  signinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = patInput.value.trim();
    if (!token) return;
    setMessage(signinError, '');
    signinBtn.disabled = true;
    signinBtn.textContent = 'Verifying…';
    try {
      const res = await fetch(`${API}/repos/${REPO}`, {
        headers: {
          Accept: 'application/vnd.github+json',
          Authorization: `Bearer ${token}`,
        },
      });
      if (!res.ok) {
        const detail = res.status === 401
          ? 'Token is invalid or expired.'
          : res.status === 404
            ? 'Token does not have access to this repository.'
            : `GitHub returned ${res.status}.`;
        setMessage(signinError, detail);
        return;
      }
      localStorage.setItem(STORAGE_KEY, token);
      showSignedIn();
    } catch (err) {
      setMessage(signinError, `Network error: ${err.message}`);
    } finally {
      signinBtn.disabled = false;
      signinBtn.textContent = 'Sign in';
    }
  });

  signoutBtn.addEventListener('click', () => {
    localStorage.removeItem(STORAGE_KEY);
    showSignedOut();
  });

  // --- Live preview ----------------------------------------------------

  function renderPreview() {
    const md = bodyInput.value || '';
    if (!md.trim()) {
      preview.innerHTML = '<p class="preview-empty">Preview will appear here.</p>';
      return;
    }
    try {
      preview.innerHTML = marked.parse(md);
    } catch (err) {
      preview.innerHTML = `<p class="preview-empty">Preview error: ${err.message}</p>`;
    }
  }

  bodyInput.addEventListener('input', renderPreview);

  // --- Publish ---------------------------------------------------------

  essayForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    setMessage(publishError, '');
    setMessage(publishSuccess, '');

    const title = $('title').value.trim();
    const subtitle = $('subtitle').value.trim();
    const date = $('date').value;
    const description = $('description').value.trim();
    const draft = $('draft').checked;
    const body = bodyInput.value;

    if (!title || !date || !body.trim()) {
      setMessage(publishError, 'Title, date, and body are required.');
      return;
    }

    const slug = slugify(title);
    if (!slug) {
      setMessage(publishError, 'Title must contain at least one alphanumeric character.');
      return;
    }

    const path = `${ESSAYS_PATH}/${slug}.mdx`;
    const file = buildMdx({ title, subtitle, date, description, draft, body });
    const encoded = utf8ToBase64(file);

    publishBtn.disabled = true;
    publishBtn.textContent = 'Publishing…';

    try {
      // Check for existing file (so we can give a clean error rather than 422).
      const existing = await ghFetch(`/repos/${REPO}/contents/${path}`);
      if (existing.ok) {
        setMessage(
          publishError,
          `An essay already exists at ${path}. Choose a different title.`,
        );
        return;
      }

      const res = await ghFetch(`/repos/${REPO}/contents/${path}`, {
        method: 'PUT',
        body: JSON.stringify({
          message: `Add essay: ${title}`,
          content: encoded,
          branch: 'main',
        }),
      });

      if (res.status === 401) {
        localStorage.removeItem(STORAGE_KEY);
        showSignedOut();
        setMessage(signinError, 'Token expired or revoked. Sign in again.');
        return;
      }

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        setMessage(publishError, `GitHub error: ${data.message || res.status}`);
        return;
      }

      const data = await res.json();
      const commitUrl = data.commit?.html_url || data.content?.html_url;
      const liveUrl = draft ? null : `/essays/${slug}/`;

      let html = `Published <code>${path}</code>. Vercel is rebuilding now.`;
      if (commitUrl) html += ` <a href="${commitUrl}" target="_blank" rel="noopener">View commit ↗</a>`;
      if (liveUrl) html += ` &middot; <a href="${liveUrl}">Visit essay</a>`;
      else html += ` &middot; Saved as draft.`;

      setMessage(publishSuccess, html, 'html');

      // Clear the form except date stays as today
      $('title').value = '';
      $('subtitle').value = '';
      $('description').value = '';
      $('draft').checked = true;
      bodyInput.value = '';
      renderPreview();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      setMessage(publishError, `Network error: ${err.message}`);
    } finally {
      publishBtn.disabled = false;
      publishBtn.textContent = 'Publish';
    }
  });

  resetBtn.addEventListener('click', () => {
    if (!confirm('Clear all fields?')) return;
    essayForm.reset();
    $('date').value = new Date().toISOString().slice(0, 10);
    $('draft').checked = true;
    setMessage(publishError, '');
    setMessage(publishSuccess, '');
    renderPreview();
  });

  // --- Bootstrap -------------------------------------------------------

  if (localStorage.getItem(STORAGE_KEY)) {
    showSignedIn();
  } else {
    showSignedOut();
  }
  renderPreview();
</script>

<style>
  .admin {
    width: 100%;
  }

  .admin-pane {
    margin-top: 1.5em;
  }

  .admin-intro {
    color: var(--ink-soft);
    font-size: 0.95em;
    line-height: 1.55;
    margin-bottom: 2em;
  }

  .admin-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5em;
    padding-bottom: 1em;
    border-bottom: 1px solid var(--rule);
  }

  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 1.6em;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  .field-row {
    display: grid;
    grid-template-columns: minmax(0, 16rem) 1fr;
    gap: 1.5em 2em;
    align-items: start;
  }

  @media (max-width: 32rem) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }

  .field-checkbox {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5em 0.7em;
  }

  .field-checkbox input {
    width: 1.05rem;
    height: 1.05rem;
    accent-color: var(--accent);
    margin: 0;
  }

  .field-checkbox .label {
    margin: 0;
  }

  .field-checkbox .hint {
    flex-basis: 100%;
    margin: 0;
  }

  .label {
    font-variant-caps: all-small-caps;
    letter-spacing: 0.18em;
    font-weight: 500;
    color: var(--ink-soft);
    font-size: 0.95em;
  }

  .label .optional {
    font-variant-caps: normal;
    letter-spacing: 0;
    color: var(--ink-faint);
    font-style: italic;
    font-size: 0.85em;
    margin-left: 0.4em;
  }

  .hint {
    color: var(--ink-faint);
    font-size: 0.88em;
    line-height: 1.4;
    font-style: italic;
  }

  .hint code {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Georgia, serif;
    font-style: normal;
    font-size: 0.95em;
    color: var(--ink-soft);
  }

  .hint-inline {
    font-style: italic;
    flex: 1;
    text-align: right;
  }

  input[type='text'],
  input[type='password'],
  input[type='date'],
  textarea {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--ink);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--rule);
    padding: 0.45em 0.1em;
    line-height: 1.4;
    width: 100%;
    transition: border-color 0.15s ease;
  }

  input[type='text']:focus,
  input[type='password']:focus,
  input[type='date']:focus,
  textarea:focus {
    outline: none;
    border-bottom-color: var(--accent);
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--ink-faint);
    font-style: italic;
  }

  /* Body editor + preview */

  .field-body {
    gap: 0.6em;
  }

  .body-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1em;
    flex-wrap: wrap;
  }

  .body-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 2em;
    align-items: stretch;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1em 0;
    min-height: 28rem;
  }

  @media (max-width: 50rem) {
    .body-split {
      grid-template-columns: 1fr;
    }
  }

  textarea#body {
    border: none;
    padding: 0;
    resize: vertical;
    min-height: 28rem;
    line-height: 1.55;
    font-size: 1.05rem;
  }

  textarea#body:focus {
    border: none;
    outline: none;
  }

  .preview-pane {
    border-left: 1px solid var(--rule);
    padding-left: 2em;
    overflow-x: hidden;
    word-wrap: break-word;
  }

  @media (max-width: 50rem) {
    .preview-pane {
      border-left: none;
      border-top: 1px solid var(--rule);
      padding-left: 0;
      padding-top: 1.5em;
    }
  }

  .preview-pane .essay-body {
    font-size: 1rem;
  }

  /* Disable drop cap inside preview — looks odd in a small pane */
  .preview-pane .essay-body > p:first-of-type::first-letter {
    initial-letter: unset;
    -webkit-initial-letter: unset;
    font-size: inherit;
    margin-right: 0;
  }

  .preview-empty {
    color: var(--ink-faint);
    font-style: italic;
  }

  /* Buttons */

  .button {
    align-self: flex-start;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-variant-caps: all-small-caps;
    letter-spacing: 0.18em;
    font-weight: 500;
    color: var(--paper);
    background: var(--accent);
    border: none;
    padding: 0.7em 1.6em;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .button:hover:not(:disabled) {
    background: var(--accent-soft);
  }

  .button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .link-button {
    background: none;
    border: none;
    padding: 0;
    color: var(--ink-soft);
    font-family: var(--font-serif);
    font-size: 0.95em;
    font-style: italic;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 0.2em;
  }

  .link-button:hover {
    color: var(--accent);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1.5em;
  }

  /* Messages */

  .message {
    margin: 0;
    padding: 0.7em 1em;
    font-size: 0.95em;
    line-height: 1.5;
    border-left: 2px solid var(--rule);
  }

  .message.error {
    color: var(--accent);
    border-left-color: var(--accent);
    background: rgba(107, 39, 55, 0.04);
  }

  .message.success {
    color: var(--ink);
    border-left-color: var(--ink-soft);
    background: rgba(74, 66, 57, 0.04);
  }

  .message code {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Georgia, serif;
    font-style: italic;
    font-size: 0.95em;
  }
</style>
